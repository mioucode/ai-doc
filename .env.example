# 复制为 .env.development 后按需修改（.env 已被 gitignore）

# AgentLoop API 基路径（开发走 Vite 代理时保持默认即可）
VITE_API_BASE_URL=/api/agentloop

# 为 true 时注入 X-Legacy-*（须与 sessionStorage.user 或下方兜底同时满足三必填）
VITE_USE_LEGACY_AUTH_HEADER=true

# 当 BSP 用户信息未写入 sessionStorage 时的本地兜底（联调用）
VITE_LEGACY_USER_ID=dev-user
VITE_LEGACY_ACCOUNT=dev
VITE_LEGACY_NAME=开发者

# BSP 应用编码（可选）
# VITE_BSP_APP_CODE=AI-POLICE
